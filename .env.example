# Signal STOCK 환경변수 — 실제 키는 절대 커밋하지 말 것. 이 파일은 문서화 용도.

# 배포 환경 감지 (로컬 dev는 비워둠)
APP_ENV=

# 세션 쿠키 시크릿 등은 auth.py가 자체 생성하므로 별도 키 불필요.

# --- 한국 시세/공시 (2단계 수집기 연동 예정) ---
KRX_API_KEY=
DART_API_KEY=

# --- KIS Developers (모의투자 자동매매봇, BACKLOG #7) ---
# KIS_ENV=demo(모의투자) 고정 권장 — prod로 바꾸면 실계좌 주문이 나갈 수 있음
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CD=01
KIS_ENV=demo

# --- 한국은행 ECOS (금리·거시지표) ---
ECOS_API_KEY=

# --- FRED (미국 거시경제 — CPI/FOMC 기준금리/국채금리, 시황 판단 지표) ---
FRED_API_KEY=

# --- 해외 시세 (2단계) ---
ALPHAVANTAGE_API_KEY=

# --- 토스증권 Open API (시장데이터: US/국내 시세·발행주식수·투자경고, 읽기전용) ---
# 있으면 US 시세를 KIS 대신 토스로(안정), 발행주식수로 US 시총(AV 병목 없이), 투자경고 매수 veto.
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# --- 뉴스/검색 ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
YOUTUBE_API_KEY=

# --- AI 리포트/해설/자문 (없으면 규칙기반 폴백) ---
ANTHROPIC_API_KEY=

# --- 자동매매 백엔드/안전장치 ---
# BROKER_BACKEND: paper(자체 모의계좌) | kis. 미설정 시 KIS 자격증명 있으면 kis, 없으면 paper
BROKER_BACKEND=
PAPER_SEED_CASH=10000000
ALLOW_REAL_ORDERS=              # 실계좌(KIS_ENV!=demo) 실주문 이중 안전장치 — true여야만 실주문
BOT_KILL_SWITCH=               # true면 긴급정지(어떤 주문도 안 나감)
BOT_DAILY_LOSS_LIMIT_PCT=0.08  # 당일 손실 이 % 초과 시 신규매수 중단
BOT_RUN_INTERVAL_MINUTES=30          # 봇·LLM·about/moves 백필
QUOTE_REFRESH_INTERVAL_MINUTES=10    # 장중 토스 현재가만(봇과 분리)

# --- 관리자(엔진·KB적재·데이터 갱신 접근) — 콤마 구분 이메일 ---
ADMIN_EMAILS=

# --- KB 외부 소스 ---
FANDING_DEVICE_UID=            # fanding 미주은
FANDING_TT=                    # 세션토큰 — 만료 시 갱신 필요
OUTSTANDING_AUTHORS=           # 아웃스탠딩 작가 whitelist(콤마,@없이). 기본 oky97(오건영)
OUTSTANDING_COOKIE=            # 유료 작가 기고 조회 시에만
YOUTUBE_CHANNELS=              # 유튜브 채널 whitelist(콤마,@없이). 기본 sbs_explained

# --- 백업(선택) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUP_S3_BUCKET=
