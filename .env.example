# Signal STOCK 환경변수 — 실제 키는 절대 커밋하지 말 것. 이 파일은 문서화 용도.

# 배포 환경 감지 (로컬 dev는 비워둠)
APP_ENV=

# 세션 쿠키 시크릿 등은 auth.py가 자체 생성하므로 별도 키 불필요.

# --- 한국 시세/공시 (2단계 수집기 연동 예정) ---
KRX_API_KEY=
DART_API_KEY=

# --- 한국은행 ECOS (금리·거시지표) ---
ECOS_API_KEY=

# --- 해외 시세 (2단계) ---
ALPHAVANTAGE_API_KEY=

# --- 뉴스/검색 ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
YOUTUBE_API_KEY=

# --- AI 리포트 ---
ANTHROPIC_API_KEY=

# --- 백업(선택) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUP_S3_BUCKET=
